# URLs
# Local Development
SERVER_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
# Production (Set these in Render environment variables)
# SERVER_URL=https://server.nexotype.com
# FRONTEND_URL=https://client.nexotype.com

# Database URL - Coolify PostgreSQL (using SSL)
DATABASE_URL=postgresql+asyncpg://postgres:your-password@your-server-ip:6031/nexotype?ssl=require

# Supabase PostgreSQL (commented out)
# DATABASE_URL=postgresql+asyncpg://postgres.your-project-id:your-password@aws-1-eu-central-1.pooler.supabase.com:5432/postgres?ssl=require

# Local Database URLs (commented out)
# DATABASE_URL=postgresql+asyncpg://username:password@localhost:5433/nexotype_db
# TEST_DATABASE_URL=postgresql+asyncpg://username:password@localhost:5433/test_nexotype_db

# Database - Coolify PostgreSQL (individual params if needed)
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-password
DB_HOST=your-server-ip
DB_PORT=6031

# Supabase PostgreSQL (individual params - commented out)
# DB_NAME=postgres
# DB_USER=postgres.your-project-id
# DB_PASSWORD=your-password
# DB_HOST=aws-1-eu-central-1.pooler.supabase.com
# DB_PORT=5432

# Security & JWT Settings
SECRET_KEY=your-secret-key-generate-a-strong-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
BACKEND_CORS_ORIGINS=http://localhost:3000,https://client.nexotype.com

# Stripe Settings (switch sk_test_ to sk_live_ when going live)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Google OAuth Settings
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Local Development
GOOGLE_REDIRECT_URI=http://localhost:3000/login
# Production (Set these in Render environment variables)
# GOOGLE_REDIRECT_URI=https://client.nexotype.com/login

# Email Settings
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password
EMAILS_ENABLED=True