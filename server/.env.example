# URLs
# Local Development
SERVER_URL=http://localhost:8002
FRONTEND_URL=http://localhost:3002
# Production (Set these in Coolify environment variables)
# SERVER_URL=https://server.nudgio.tech
# FRONTEND_URL=https://client.nudgio.tech

# Database URL - Coolify PostgreSQL with SSL (public URL for local dev)
# DATABASE_URL=postgresql+asyncpg://postgres:your-password@your-server-ip:PORT/nudgio?ssl=require

# Local Database URLs (commented out)
# DATABASE_URL=postgresql+asyncpg://username:password@localhost:5433/nudgio_db
# TEST_DATABASE_URL=postgresql+asyncpg://username:password@localhost:5433/test_nudgio_db

# Database - Coolify PostgreSQL (individual params if needed)
DB_NAME=nudgio
DB_USER=postgres
DB_PASSWORD=your-password
DB_HOST=your-server-ip
DB_PORT=5432

# Security & JWT Settings
SECRET_KEY=your-secret-key-generate-a-strong-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
BACKEND_CORS_ORIGINS=http://localhost:3002,https://client.nudgio.tech

# Stripe Settings (switch sk_test_ to sk_live_ when going live)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Google OAuth Settings
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Local Development
GOOGLE_REDIRECT_URI=http://localhost:3002/login
# Production (Set these in Coolify environment variables)
# GOOGLE_REDIRECT_URI=https://client.nudgio.tech/login

# Email Settings
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password
EMAILS_ENABLED=True

# Shopify OAuth Settings
SHOPIFY_CLIENT_ID=your-shopify-client-id
SHOPIFY_CLIENT_SECRET=your-shopify-client-secret
SHOPIFY_SCOPES=read_products,read_orders
# Local Development
SHOPIFY_REDIRECT_URI=http://localhost:8002/ecommerce/shopify/callback
# Production (Set these in Coolify environment variables)
# SHOPIFY_REDIRECT_URI=https://server.nudgio.tech/ecommerce/shopify/callback
