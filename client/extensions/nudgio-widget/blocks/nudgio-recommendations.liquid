{% comment %}
  Nudgio Recommendations — Theme App Extension Block

  Renders an iframe pointing to the App Proxy URL which serves
  recommendation widget HTML (Tailwind-styled product cards).

  The iframe isolates widget styles (Tailwind CDN) from the merchant's
  theme — same approach as the embedded Components page preview.

  Widget types:
  - bestsellers: no product context needed
  - cross-sell, upsell, similar: pass current product.id from Liquid context

  Shopify App Proxy rewrites:
    https://shop.myshopify.com/apps/nudgio-widget/bestsellers?top=4&...
    → https://server.nudgio.tech/ecommerce/shopify/app-proxy/bestsellers?top=4&...&shop=...&signature=...
{% endcomment %}

{% comment %} Build the App Proxy URL with widget settings from Theme Editor {% endcomment %}
{% assign proxy_base = "/apps/nudgio-widget/" | append: block.settings.widget_type %}

{% comment %} URL-encode color values separately — encoding the full string would encode ? & = too {% endcomment %}
{% assign widget_bg_color_enc = block.settings.widget_bg_color | url_encode %}
{% assign title_color_enc = block.settings.title_color | url_encode %}
{% assign card_bg_color_enc = block.settings.card_bg_color | url_encode %}
{% assign card_border_color_enc = block.settings.card_border_color | url_encode %}
{% assign product_title_color_enc = block.settings.product_title_color | url_encode %}
{% assign price_color_enc = block.settings.price_color | url_encode %}
{% assign button_bg_color_enc = block.settings.button_bg_color | url_encode %}
{% assign button_text_color_enc = block.settings.button_text_color | url_encode %}

{% comment %} URL-encode CSS values that may contain special characters {% endcomment %}
{% assign card_border_radius_enc = block.settings.card_border_radius | url_encode %}
{% assign image_radius_enc = block.settings.image_radius | url_encode %}
{% assign button_radius_enc = block.settings.button_radius | url_encode %}

{% comment %} Build query string — one param per visual setting {% endcomment %}
{% assign params = "?top=" | append: block.settings.product_count %}
{% comment %} Algorithm settings {% endcomment %}
{% assign params = params | append: "&lookback_days=" | append: block.settings.lookback_days %}
{% assign params = params | append: "&method=" | append: block.settings.method %}
{% assign params = params | append: "&min_price_increase_percent=" | append: block.settings.min_price_increase_percent %}
{% comment %} Group 1: Widget Container {% endcomment %}
{% assign params = params | append: "&widget_bg_color=" | append: widget_bg_color_enc %}
{% assign params = params | append: "&widget_padding=" | append: block.settings.widget_padding %}
{% comment %} Group 2: Widget Title {% endcomment %}
{% if block.settings.widget_title != blank %}
  {% assign widget_title_enc = block.settings.widget_title | url_encode %}
  {% assign params = params | append: "&widget_title=" | append: widget_title_enc %}
{% endif %}
{% assign params = params | append: "&title_color=" | append: title_color_enc %}
{% assign params = params | append: "&title_size=" | append: block.settings.title_size %}
{% assign params = params | append: "&title_alignment=" | append: block.settings.title_alignment %}
{% comment %} Group 3: Layout {% endcomment %}
{% assign params = params | append: "&widget_style=" | append: block.settings.widget_style %}
{% assign params = params | append: "&widget_columns=" | append: block.settings.widget_columns %}
{% assign params = params | append: "&gap=" | append: block.settings.gap %}
{% comment %} Group 4: Product Card {% endcomment %}
{% assign params = params | append: "&card_bg_color=" | append: card_bg_color_enc %}
{% assign params = params | append: "&card_border_radius=" | append: card_border_radius_enc %}
{% assign params = params | append: "&card_border_width=" | append: block.settings.card_border_width %}
{% assign params = params | append: "&card_border_color=" | append: card_border_color_enc %}
{% assign params = params | append: "&card_shadow=" | append: block.settings.card_shadow %}
{% assign params = params | append: "&card_padding=" | append: block.settings.card_padding %}
{% assign params = params | append: "&card_hover=" | append: block.settings.card_hover %}
{% comment %} Group 5: Product Image {% endcomment %}
{% assign params = params | append: "&image_aspect=" | append: block.settings.image_aspect %}
{% assign params = params | append: "&image_fit=" | append: block.settings.image_fit %}
{% assign params = params | append: "&image_radius=" | append: image_radius_enc %}
{% comment %} Group 6: Product Title in Card {% endcomment %}
{% assign params = params | append: "&product_title_color=" | append: product_title_color_enc %}
{% assign params = params | append: "&product_title_size=" | append: block.settings.product_title_size %}
{% assign params = params | append: "&product_title_weight=" | append: block.settings.product_title_weight %}
{% assign params = params | append: "&product_title_lines=" | append: block.settings.product_title_lines %}
{% assign params = params | append: "&product_title_alignment=" | append: block.settings.product_title_alignment %}
{% comment %} Group 7: Price {% endcomment %}
{% unless block.settings.show_price %}
  {% assign params = params | append: "&show_price=false" %}
{% endunless %}
{% assign params = params | append: "&price_color=" | append: price_color_enc %}
{% assign params = params | append: "&price_size=" | append: block.settings.price_size %}
{% comment %} Group 8: CTA Button {% endcomment %}
{% if block.settings.button_text != blank %}
  {% assign button_text_enc = block.settings.button_text | url_encode %}
  {% assign params = params | append: "&button_text=" | append: button_text_enc %}
{% endif %}
{% assign params = params | append: "&button_bg_color=" | append: button_bg_color_enc %}
{% assign params = params | append: "&button_text_color=" | append: button_text_color_enc %}
{% assign params = params | append: "&button_radius=" | append: button_radius_enc %}
{% assign params = params | append: "&button_size=" | append: block.settings.button_size %}
{% assign params = params | append: "&button_variant=" | append: block.settings.button_variant %}
{% if block.settings.button_full_width %}
  {% assign params = params | append: "&button_full_width=true" %}
{% endif %}

{% comment %} Product ID: use manual value if set, otherwise auto-detect from Liquid product context {% endcomment %}
{% if block.settings.product_id != blank %}
  {% assign params = params | append: "&product_id=" | append: block.settings.product_id %}
{% elsif block.settings.widget_type != "bestsellers" and product %}
  {% assign params = params | append: "&product_id=" | append: product.id %}
{% endif %}

{% comment %} Dummy trailing parameter — Shopify Theme Editor appends ?oseid=... to the
   iframe src, contaminating the last URL parameter's value. This sacrificial
   param absorbs the editor suffix so real params stay clean. {% endcomment %}
{% assign params = params | append: "&_=1" %}

{% assign iframe_src = proxy_base | append: params %}

{% comment %} Guard: product-specific widget types require a product page context {% endcomment %}
{% if block.settings.widget_type != "bestsellers" and product == nil and block.settings.product_id == blank %}
  <div class="nudgio-recommendations" {{ block.shopify_attributes }}>
    <p style="padding: 16px; color: #6b7280; font-size: 14px; text-align: center;">
      This widget type requires a product page. Move this block to a product page template,
      or switch the widget type to "Bestsellers" for non-product pages.
    </p>
  </div>
{% else %}
  <div class="nudgio-recommendations" {{ block.shopify_attributes }}>
    <iframe
      src="{{ iframe_src }}"
      style="width: 100%; border: none; min-height: 200px; overflow: hidden;"
      title="Nudgio Recommendations"
      loading="lazy"
      id="nudgio-widget-{{ block.id }}"
    ></iframe>
  </div>

  <script src="{{ 'nudgio-widget.js' | asset_url }}" defer></script>
{% endif %}

{% schema %}
{
  "name": "Nudgio Technologies",
  "target": "section",
  "settings": [
    {
      "type": "select",
      "id": "widget_type",
      "label": "Widget Type",
      "default": "bestsellers",
      "options": [
        { "value": "bestsellers", "label": "Bestsellers" },
        { "value": "cross-sell", "label": "Cross-sell" },
        { "value": "upsell", "label": "Upsell" },
        { "value": "similar", "label": "Similar Products" }
      ],
      "info": "Cross-sell, upsell, and similar require a product page context."
    },
    {
      "type": "range",
      "id": "product_count",
      "label": "Number of Products",
      "min": 1,
      "max": 20,
      "step": 1,
      "default": 4
    },
    {
      "type": "text",
      "id": "product_id",
      "label": "Product ID",
      "info": "Leave empty to auto-detect on product pages. Set manually to show recommendations for a specific product on any page."
    },
    {
      "type": "range",
      "id": "lookback_days",
      "label": "Lookback Days",
      "min": 1,
      "max": 365,
      "step": 1,
      "default": 30,
      "info": "Number of days to analyze for recommendations. Used by Bestsellers and Cross-sell."
    },
    {
      "type": "select",
      "id": "method",
      "label": "Ranking Method",
      "default": "volume",
      "options": [
        { "value": "volume", "label": "Volume (units sold)" },
        { "value": "value", "label": "Value (revenue)" },
        { "value": "balanced", "label": "Balanced (volume + value)" }
      ],
      "info": "Bestseller ranking method. Only affects the Bestsellers widget type."
    },
    {
      "type": "range",
      "id": "min_price_increase_percent",
      "label": "Min Price Increase %",
      "min": 1,
      "max": 100,
      "step": 1,
      "default": 10,
      "info": "Only show products at least this % more expensive. Only affects the Upsell widget type."
    },
    {
      "type": "header",
      "content": "Widget"
    },
    {
      "type": "color",
      "id": "widget_bg_color",
      "label": "Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "select",
      "id": "widget_padding",
      "label": "Padding",
      "default": "md",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" }
      ]
    },
    {
      "type": "text",
      "id": "widget_title",
      "label": "Title Text",
      "info": "Leave empty for auto-default based on widget type (e.g., \"Popular now\", \"Frequently bought together\")."
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title Color",
      "default": "#111827"
    },
    {
      "type": "select",
      "id": "title_size",
      "label": "Title Size",
      "default": "lg",
      "options": [
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" },
        { "value": "xl", "label": "Extra Large" }
      ]
    },
    {
      "type": "select",
      "id": "title_alignment",
      "label": "Title Alignment",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ]
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "widget_style",
      "label": "Layout Style",
      "default": "grid",
      "options": [
        { "value": "grid", "label": "Grid Cards" },
        { "value": "carousel", "label": "Carousel" }
      ]
    },
    {
      "type": "range",
      "id": "widget_columns",
      "label": "Columns",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 4,
      "info": "Max columns at full width. Responsive: 1 col mobile → 2 col tablet → N col desktop."
    },
    {
      "type": "select",
      "id": "gap",
      "label": "Card Gap",
      "default": "md",
      "options": [
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" }
      ]
    },
    {
      "type": "header",
      "content": "Product Card"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card Background",
      "default": "#FFFFFF"
    },
    {
      "type": "text",
      "id": "card_border_radius",
      "label": "Card Border Radius",
      "default": "8px",
      "info": "CSS border-radius (e.g., 8px, 0.5rem)."
    },
    {
      "type": "select",
      "id": "card_border_width",
      "label": "Card Border Width",
      "default": "0",
      "options": [
        { "value": "0", "label": "None" },
        { "value": "1", "label": "1px" },
        { "value": "2", "label": "2px" }
      ]
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Card Border Color",
      "default": "#E5E7EB"
    },
    {
      "type": "select",
      "id": "card_shadow",
      "label": "Card Shadow",
      "default": "md",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" }
      ]
    },
    {
      "type": "select",
      "id": "card_padding",
      "label": "Card Padding",
      "default": "md",
      "options": [
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" }
      ]
    },
    {
      "type": "select",
      "id": "card_hover",
      "label": "Card Hover Effect",
      "default": "lift",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "lift", "label": "Lift" },
        { "value": "shadow", "label": "Shadow" },
        { "value": "glow", "label": "Glow" }
      ]
    },
    {
      "type": "header",
      "content": "Product Image"
    },
    {
      "type": "select",
      "id": "image_aspect",
      "label": "Image Aspect Ratio",
      "default": "square",
      "options": [
        { "value": "square", "label": "Square (1:1)" },
        { "value": "portrait", "label": "Portrait (3:4)" },
        { "value": "landscape", "label": "Landscape (16:9)" }
      ]
    },
    {
      "type": "select",
      "id": "image_fit",
      "label": "Image Fit",
      "default": "cover",
      "options": [
        { "value": "cover", "label": "Cover (crop)" },
        { "value": "contain", "label": "Contain (fit)" }
      ]
    },
    {
      "type": "text",
      "id": "image_radius",
      "label": "Image Border Radius",
      "default": "8px",
      "info": "CSS border-radius (e.g., 8px, 0)."
    },
    {
      "type": "header",
      "content": "Product Title"
    },
    {
      "type": "color",
      "id": "product_title_color",
      "label": "Title Color",
      "default": "#1F2937"
    },
    {
      "type": "select",
      "id": "product_title_size",
      "label": "Title Size",
      "default": "sm",
      "options": [
        { "value": "xs", "label": "Extra Small" },
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" }
      ]
    },
    {
      "type": "select",
      "id": "product_title_weight",
      "label": "Title Weight",
      "default": "semibold",
      "options": [
        { "value": "normal", "label": "Normal" },
        { "value": "medium", "label": "Medium" },
        { "value": "semibold", "label": "Semibold" },
        { "value": "bold", "label": "Bold" }
      ]
    },
    {
      "type": "range",
      "id": "product_title_lines",
      "label": "Max Lines",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2,
      "info": "Product title truncation after N lines."
    },
    {
      "type": "select",
      "id": "product_title_alignment",
      "label": "Title Alignment",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ]
    },
    {
      "type": "header",
      "content": "Price"
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "label": "Show Price",
      "default": true
    },
    {
      "type": "color",
      "id": "price_color",
      "label": "Price Color",
      "default": "#111827"
    },
    {
      "type": "select",
      "id": "price_size",
      "label": "Price Size",
      "default": "md",
      "options": [
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" }
      ]
    },
    {
      "type": "header",
      "content": "CTA Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "View"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Button Color",
      "default": "#3B82F6"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Color",
      "default": "#FFFFFF"
    },
    {
      "type": "text",
      "id": "button_radius",
      "label": "Button Border Radius",
      "default": "6px",
      "info": "CSS border-radius (e.g., 6px, 9999px for pill)."
    },
    {
      "type": "select",
      "id": "button_size",
      "label": "Button Size",
      "default": "md",
      "options": [
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" }
      ]
    },
    {
      "type": "select",
      "id": "button_variant",
      "label": "Button Style",
      "default": "solid",
      "options": [
        { "value": "solid", "label": "Solid (filled)" },
        { "value": "outline", "label": "Outline (border)" },
        { "value": "ghost", "label": "Ghost (transparent)" }
      ]
    },
    {
      "type": "checkbox",
      "id": "button_full_width",
      "label": "Full Width Button",
      "default": false
    }
  ]
}
{% endschema %}
